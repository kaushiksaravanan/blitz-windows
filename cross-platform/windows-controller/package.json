{
  "name": "blitz-windows-controller",
  "version": "1.0.0",
  "description": "Blitz Windows Controller — Android development tools for Windows",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/ensure-electron-cjs.cjs && concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"electron .\"",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/ensure-electron-cjs.cjs",
    "build:all": "npm run build && npm run build:electron",
    "start": "node scripts/ensure-electron-cjs.cjs && electron .",
    "preview": "vite preview",
    "dist": "npm run build:all && electron-builder"
  },
  "dependencies": {
    "@blitz/core": "file:../core",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "lucide-react": "^0.400.0",
    "playwright-core": "^1.58.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "ws": "^8.18.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.blitz.windows-controller",
    "productName": "Blitz",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
