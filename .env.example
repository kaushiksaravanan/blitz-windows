# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# --- Android SDK (auto-detected, override only if needed) ---
# ANDROID_HOME=C:\Users\<you>\AppData\Local\Android\Sdk

# --- Java (auto-detected from PATH/JAVA_HOME, override only if needed) ---
# JAVA_HOME=C:\Program Files\Java\jdk-17

# --- Flutter (optional, only if building Flutter projects) ---
# FLUTTER_SDK_PATH=C:\Users\<you>\flutter

# --- Companion Server (Android companion app connection) ---
# COMPANION_PORT=9400
# COMPANION_API_KEY=<random-secret>

# --- Play Store Publishing (Chrome must be launched with remote debugging) ---
# CHROME_DEBUG_PORT=9222
